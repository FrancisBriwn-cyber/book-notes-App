<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error — My Book Notes</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="page-wrapper">

      <!-- ── Header ── -->
      <header class="site-header">
        <div class="header-brand">
          <h1>📚 My Book Notes</h1>
          <p>Books I've read · notes I've kept</p>
        </div>
        <a href="/" class="btn btn-secondary" id="back-home-btn">← Home</a>
      </header>

      <!-- ── Error message ── -->
      <div class="error-page">
        <div class="err-code">⚠️</div>
        <h2>Something went wrong</h2>
        <p><%= message || "An unexpected error occurred." %></p>
        <a href="/" class="btn btn-primary" id="error-home-btn">Go back home</a>
      </div>

    </div>
  </body>
</html>
